<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mode_popup_root"
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#1E1E1E"
    app:cardCornerRadius="12dp"
    app:cardElevation="8dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="6dp">

        <!-- All -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mode_all"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:rippleColor="#33FFFFFF"
            app:strokeWidth="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/play_button_rounded"
                    android:tint="#A0A0A0"
                    android:scaleType="centerInside"
                    android:layout_marginEnd="12dp"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="All"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"/>
                <TextView
                    android:id="@+id/check_all"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:fontFamily="@font/materialicons"
                    android:text="check_circle"
                    android:textColor="#4CAF50"
                    android:textSize="16sp"
                    android:gravity="center"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- FadCam -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mode_fadcam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:rippleColor="#33FFFFFF"
            app:strokeWidth="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_vid_cam"
                    android:tint="#A0A0A0"
                    android:scaleType="centerInside"
                    android:layout_marginEnd="12dp"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="FadCam"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"/>
                <TextView
                    android:id="@+id/check_fadcam"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:fontFamily="@font/materialicons"
                    android:text="radio_button_unchecked"
                    android:textColor="#666666"
                    android:textSize="16sp"
                    android:gravity="center"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- FadRec -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mode_fadrec"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:rippleColor="#33FFFFFF"
            app:strokeWidth="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/screen_recorder"
                    android:tint="#A0A0A0"
                    android:scaleType="centerInside"
                    android:layout_marginEnd="12dp"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="FadRec"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"/>
                <TextView
                    android:id="@+id/check_fadrec"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:fontFamily="@font/materialicons"
                    android:text="radio_button_unchecked"
                    android:textColor="#666666"
                    android:textSize="16sp"
                    android:gravity="center"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
