<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Camera Preview (Background, full screen) -->
    <androidx.camera.view.PreviewView
        android:id="@+id/qr_preview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Dimming overlay with transparent scan window cutout -->
    <com.fadcam.ui.miniapps.ScanOverlayView
        android:id="@+id/qr_dim_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Header Bar: close + title + gallery -->
    <LinearLayout
        android:id="@+id/qr_header_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/qr_close"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"
            android:src="@drawable/ic_close"
            android:contentDescription="@string/button_close"
            android:tint="@android:color/white"
            android:background="@drawable/settings_home_row_bg"
            android:clickable="true"
            android:focusable="true" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:orientation="vertical">

            <com.fadcam.ui.utils.AnimatedTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="start|center_vertical"
                android:text="@string/mini_app_qr_scanner_title"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.02" />

        </LinearLayout>

    </LinearLayout>

    <!-- Scan Frame Container: dotted wireframe + centered pulsing red line -->
    <FrameLayout
        android:id="@+id/qr_scan_container"
        android:layout_width="280dp"
        android:layout_height="280dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Dotted wireframe border (single, no glow) -->
        <View
            android:id="@+id/qr_scan_frame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/qr_scan_frame_dotted" />

        <!-- Glowing particle animation (replaces scan line) -->
        <com.fadcam.ui.miniapps.ScanParticleView
            android:id="@+id/qr_scan_line"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Info Banner: icon + full text below scan frame, wraps content, centered -->
    <LinearLayout
        android:id="@+id/qr_info_banner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="@drawable/qr_info_banner_bg"
        app:layout_constraintTop_toBottomOf="@id/qr_scan_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintWidth_max="320dp">

        <TextView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:gravity="center"
            android:text="info"
            android:textSize="16sp"
            android:fontFamily="@font/materialicons"
            android:textColor="#80FFFFFF"
            android:layout_marginEnd="10dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/qr_info_banner_text"
            android:textColor="#AAFFFFFF"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.3" />

    </LinearLayout>

    <!-- Bottom Bar: gallery + torch buttons -->
    <LinearLayout
        android:id="@+id/qr_bottom_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="16dp"
        android:paddingBottom="36dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Gallery button -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/qr_gallery"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:gravity="center"
                android:text="photo_library"
                android:textSize="26sp"
                android:fontFamily="@font/materialicons"
                android:textColor="@android:color/white"
                android:background="@drawable/qr_torch_bottom_bg"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/button_gallery"
                android:textColor="#80FFFFFF"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- Torch button -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/qr_torch"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:padding="14dp"
                android:src="@drawable/ic_flashlight_off"
                android:contentDescription="@string/button_torch"
                android:tint="@android:color/white"
                android:background="@drawable/qr_torch_bottom_bg"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/button_torch"
                android:textColor="#80FFFFFF"
                android:textSize="11sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Result Card: slides up from bottom on scan -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/qr_result_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="20dp"
        android:visibility="gone"
        app:cardCornerRadius="20dp"
        app:cardElevation="24dp"
        app:cardBackgroundColor="#EE0F0F0F"
        app:strokeColor="#224CAF50"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- Top row: check icon + "Scanned" label + format badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:gravity="center"
                    android:text="check_circle"
                    android:textSize="18sp"
                    android:fontFamily="@font/materialicons"
                    android:textColor="#4CAF50"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/qr_result_scanned_label"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/qr_result_format"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="@string/qr_scanner_format_badge"
                    android:textColor="#4CAF50"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:background="@drawable/qr_format_badge_bg" />

            </LinearLayout>

            <!-- Scanned value dark container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:minHeight="44dp"
                android:gravity="center_vertical"
                android:background="@drawable/qr_result_value_bg">

                <TextView
                    android:id="@+id/qr_result_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:text=""
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:maxLines="6"
                    android:ellipsize="end"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>

            <!-- Hint text (hidden, kept for compatibility) -->
            <TextView
                android:id="@+id/qr_hint_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/qr_scanner_hint"
                android:textColor="#80FFFFFF"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- Copy + Share row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="14dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/qr_btn_copy"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/button_copy"
                    android:textColor="#4CAF50"
                    android:textSize="13sp"
                    app:cornerRadius="12dp"
                    app:strokeColor="#554CAF50"
                    app:strokeWidth="1dp"
                    app:icon="@drawable/ic_copy"
                    app:iconTint="#4CAF50"
                    app:iconSize="16dp"
                    app:iconPadding="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/qr_btn_share"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="@string/button_share"
                    android:textColor="#4CAF50"
                    android:textSize="13sp"
                    app:cornerRadius="12dp"
                    app:strokeColor="#554CAF50"
                    app:strokeWidth="1dp"
                    app:icon="@drawable/ic_share"
                    app:iconTint="#4CAF50"
                    app:iconSize="16dp"
                    app:iconPadding="6dp" />

            </LinearLayout>

            <!-- Scan Again full-width (green for success) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/qr_btn_scan_again"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:text="@string/button_scan_again"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                app:backgroundTint="#4CAF50"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_scan_again"
                app:iconTint="@android:color/white"
                app:iconSize="16dp"
                app:iconPadding="8dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
