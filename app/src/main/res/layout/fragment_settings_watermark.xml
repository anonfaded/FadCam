<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <!-- Fixed Header -->
    <LinearLayout
        android:id="@+id/header_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:background="@drawable/header_bar_rounded_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <ImageView
            android:id="@+id/back_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:padding="2dp"
            android:src="@drawable/ic_close"
            android:contentDescription="Back"
            android:tint="@android:color/white"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_watermark_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp"
            android:textColor="@android:color/white"/>
    </LinearLayout>

    <ScrollView
        android:id="@+id/content_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingBottom="76dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/header_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp">

            <!-- Preview Heading -->
            <TextView
                android:id="@+id/heading_preview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:text="@string/watermark_preview_heading"
                android:textColor="?attr/colorHeading"
                android:textStyle="bold" />

            <!-- Preview Mode Tabs (FadCam / FadRec) — transparent bg, dark ripple -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/preview_mode_tabs"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:layout_marginBottom="4dp"
                android:background="@android:color/transparent"
                app:tabMode="fixed"
                app:tabGravity="fill"
                app:tabIndicatorColor="?attr/colorPrimary"
                app:tabIndicatorHeight="2dp"
                app:tabPaddingStart="8dp"
                app:tabPaddingEnd="8dp"
                app:tabTextColor="?attr/colorOnSurface"
                app:tabSelectedTextColor="?attr/colorPrimary"
                app:tabRippleColor="#7A000000"
                android:elevation="0dp">
                <com.google.android.material.tabs.TabItem
                    android:id="@+id/tab_fadcam"
                    android:text="FadCam" />
                <com.google.android.material.tabs.TabItem
                    android:id="@+id/tab_fadrec"
                    android:text="FadRec" />
            </com.google.android.material.tabs.TabLayout>

            <!-- Preview Cards (ViewPager2 — snappy paging) -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/preview_pager"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:layout_marginBottom="8dp" />

            <!-- Page Indicator Dots -->
            <LinearLayout
                android:id="@+id/preview_page_dots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginBottom="12dp">
                <View
                    android:id="@+id/dot_fadcam"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/indicator_dot_active"
                    android:layout_marginEnd="8dp" />
                <View
                    android:id="@+id/dot_fadrec"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/indicator_dot_inactive" />
            </LinearLayout>
            <TextView
                android:id="@+id/text_preview_helper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:text="@string/helper_watermark_preview"
                android:textColor="@android:color/darker_gray"
                android:textSize="12sp"/>

            <!-- Options Heading -->
            <TextView
                android:id="@+id/heading_options"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="8dp"
                android:text="@string/watermark_options_heading"
                android:textColor="?attr/colorHeading"
                android:textStyle="bold" />

            <!-- Options Card -->
            <LinearLayout
                android:id="@+id/group_card_options"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/settings_group_card_bg"

>

                <!-- Watermark Style Row (value + arrow) -->
                <LinearLayout
                    android:id="@+id/row_watermark_option"
                    style="@style/SettingsGroupRow">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_settings"
                        android:tint="@android:color/darker_gray"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/watermark_style_row_title"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="?attr/colorHeading"/>
                        <TextView
                            android:id="@+id/value_watermark_style"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:text="-"
                            android:textColor="@android:color/darker_gray"
                            android:textSize="12sp"/>
                    </LinearLayout>
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_arrow_right"
                        android:tint="@android:color/darker_gray"/>
                </LinearLayout>
                <View style="@style/SettingsDivider" />

                <!-- Location Watermark Row -->
                <LinearLayout
                    android:id="@+id/row_location_watermark"
                    style="@style/SettingsGroupRow">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_location"
                        android:tint="@android:color/darker_gray"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_location_watermark_title"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="?attr/colorHeading"/>
                        <TextView
                            android:id="@+id/value_location_watermark"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:text="-"
                            android:textColor="@android:color/darker_gray"
                            android:textSize="12sp"/>
                    </LinearLayout>
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_arrow_right"
                        android:tint="@android:color/darker_gray"/>
                </LinearLayout>
                <View style="@style/SettingsDivider" />

                <!-- Location Format Row -->
                <LinearLayout
                    android:id="@+id/row_location_format"
                    style="@style/SettingsGroupRow">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_location"
                        android:tint="@android:color/darker_gray"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/location_format_title"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="?attr/colorHeading"/>
                        <TextView
                            android:id="@+id/value_location_format"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:text="Coordinates Only"
                            android:textColor="@android:color/darker_gray"
                            android:textSize="12sp"/>
                    </LinearLayout>
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_arrow_right"
                        android:tint="@android:color/darker_gray"/>
                </LinearLayout>
                <View style="@style/SettingsDivider" />

                <!-- Location Update Interval Row -->
                <LinearLayout
                    android:id="@+id/row_location_interval"
                    style="@style/SettingsGroupRow">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_settings"
                        android:tint="@android:color/darker_gray"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/location_update_interval_title"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="?attr/colorHeading"/>
                        <TextView
                            android:id="@+id/value_location_interval"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:text="5.0 seconds"
                            android:textColor="@android:color/darker_gray"
                            android:textSize="12sp"/>
                    </LinearLayout>
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_arrow_right"
                        android:tint="@android:color/darker_gray"/>
                </LinearLayout>
                <View style="@style/SettingsDivider" />

                <!-- Custom Text Row with NEW badge -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    
                    <LinearLayout
                        android:id="@+id/row_custom_text"
                        style="@style/SettingsGroupRow">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_draw_edit"
                        android:tint="@android:color/darker_gray"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/watermark_custom_text_title"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="?attr/colorHeading"/>
                        <TextView
                            android:id="@+id/value_custom_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:text="-"
                            android:textColor="@android:color/darker_gray"
                            android:textSize="12sp"
                            android:maxLines="1"
                            android:ellipsize="end"/>
                    </LinearLayout>
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_arrow_right"
                        android:tint="@android:color/darker_gray"/>
                    </LinearLayout>
                    
                    <!-- NEW Badge -->
                    <TextView
                        android:id="@+id/badge_custom_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginEnd="44dp"
                        android:background="@drawable/new_badge_background"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:text="NEW"
                        android:textColor="#FFFFFF"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:visibility="visible" />
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
