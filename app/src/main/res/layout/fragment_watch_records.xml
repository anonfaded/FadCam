<?xml version="1.0" encoding="utf-8"?>
<!--
    Watch records screen — scrollable list of recent recordings.
    Padding keeps content within the inscribed circle of round watch displays.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:paddingStart="40dp"
    android:paddingEnd="40dp"
    android:paddingTop="28dp"
    android:paddingBottom="28dp">

    <!-- Screen title -->
    <TextView
        android:id="@+id/tv_watch_records_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/watch_records_title"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Empty state: shown when no recordings exist -->
    <TextView
        android:id="@+id/tv_watch_records_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/watch_records_empty"
        android:textColor="#666666"
        android:textSize="11sp"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_watch_records_title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- List of recordings -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_watch_records"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/tv_watch_records_title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="6dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
