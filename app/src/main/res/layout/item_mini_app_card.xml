<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:layout_margin="3dp"
    android:background="@drawable/mini_app_card_bg"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/mini_card_arrow"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:layout_gravity="end|top"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:src="@drawable/ic_arrow_right"
        android:tint="@android:color/darker_gray" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/mini_card_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:textSize="28sp"
            android:textColor="@android:color/darker_gray"
            android:fontFamily="@font/materialicons" />

        <TextView
            android:id="@+id/mini_card_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="6dp"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="?attr/colorHeading"
            android:gravity="center" />

        <TextView
            android:id="@+id/mini_card_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp"
            android:textSize="10sp"
            android:textColor="@android:color/darker_gray"
            android:gravity="center" />

        <TextView
            android:id="@+id/mini_card_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_coming_soon_badge"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textColor="#FFFFFF"
            android:textSize="8sp"
            android:textStyle="bold"
            android:visibility="gone"/>
    </LinearLayout>
</FrameLayout>
