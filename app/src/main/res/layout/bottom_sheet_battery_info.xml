<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/picker_bottom_sheet_dark_gradient_bg"
        android:padding="20dp">

    <!-- Header with gradient -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/remote_battery_info"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?attr/colorHeading"
        android:paddingBottom="16dp" />

    <!-- Low Battery Warning Card -->
    <LinearLayout
        android:id="@+id/lowBatteryWarningCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FF6B6B"
        android:padding="14dp"
        android:layout_marginBottom="12dp"
        android:layout_marginStart="-20dp"
        android:layout_marginEnd="-20dp"
        android:layout_marginTop="-4dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/lowBatteryWarningText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/remote_battery_low_warning"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:gravity="center" />
    </LinearLayout>

    <!-- Current Battery Level Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/settings_group_card_bg"
        android:padding="16dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/remote_current_level"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="?attr/colorHeading" />

        <TextView
            android:id="@+id/currentBatteryLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="75%"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="?attr/colorHeading"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Battery Consumption Card -->
    <LinearLayout
        android:id="@+id/consumptionCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/settings_group_card_bg"
        android:padding="16dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/remote_battery_consumed"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="?attr/colorHeading" />

        <TextView
            android:id="@+id/consumedPercentage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15%"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="?attr/colorHeading"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/consumptionRate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/battery_unable_to_calculate"
            android:textSize="12sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Estimated Time Remaining Card -->
    <LinearLayout
        android:id="@+id/timeRemainingCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/settings_group_card_bg"
        android:padding="16dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/battery_estimate_title"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="?attr/colorHeading" />

        <TextView
            android:id="@+id/timeRemaining"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="~3.2 hours"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="?attr/colorHeading"
            android:layout_marginTop="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/battery_estimate_disclaimer"
            android:textSize="10sp"
            android:textColor="#8b949e"
            android:layout_marginTop="8dp"
            android:lineSpacingMultiplier="1.1" />
    </LinearLayout>

    <!-- Charging Status Card -->
    <LinearLayout
        android:id="@+id/chargingStatusCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/settings_group_card_bg"
        android:padding="16dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/remote_charging_status"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="?attr/colorHeading" />

        <TextView
            android:id="@+id/chargingStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/remote_not_charging"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorHeading"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Battery Warning Threshold Card -->
    <LinearLayout
        android:id="@+id/warningThresholdCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/settings_group_card_bg"
        android:padding="16dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/remote_low_battery_threshold"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="?attr/colorHeading"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:hint="@string/remote_enter_percentage_hint"
                app:hintTextColor="#8b949e"
                app:boxStrokeColor="#30363d"
                app:boxStrokeErrorColor="#da3633"
                app:cursorColor="#58a6ff"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/batteryWarningInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="20"
                    android:textColor="#e6edf3"
                    android:textColorHint="#8b949e"
                    android:minEms="3" />
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/setBatteryWarningBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/remote_set"
                android:textSize="12sp"
                android:textColor="#000000"
                android:backgroundTint="#58a6ff"
                style="@style/Widget.MaterialComponents.Button" />
        </LinearLayout>

        <TextView
            android:id="@+id/warningThresholdStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Current threshold: 20%"
            android:textSize="11sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/battery_threshold_desc"
            android:textSize="10sp"
            android:textColor="#8b949e"
            android:layout_marginTop="8dp"
            android:lineSpacingMultiplier="1.1" />
    </LinearLayout>

    <!-- Battery Capacity (mAh) Card -->
    <LinearLayout
        android:id="@+id/batteryCapacityCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/settings_group_card_bg"
        android:padding="16dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/remote_device_battery_capacity"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="?attr/colorHeading"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:hint="@string/remote_enter_mah_hint"
                app:hintTextColor="#8b949e"
                app:boxStrokeColor="#30363d"
                app:boxStrokeErrorColor="#da3633"
                app:cursorColor="#58a6ff"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/batteryCapacityInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="5000"
                    android:textColor="#e6edf3"
                    android:textColorHint="#8b949e"
                    android:minEms="4" />
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/setBatteryCapacityBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/remote_save"
                android:textSize="12sp"
                android:textColor="#000000"
                android:backgroundTint="#58a6ff"
                style="@style/Widget.MaterialComponents.Button" />
        </LinearLayout>

        <TextView
            android:id="@+id/batteryCapacityStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Current capacity: 5000 mAh"
            android:textSize="11sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/battery_capacity_desc"
            android:textSize="10sp"
            android:textColor="#8b949e"
            android:layout_marginTop="8dp"
            android:lineSpacingMultiplier="1.1" />

        <!-- Dynamic Examples Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="#1a1b1e"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/remote_estimates_for_device"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#b0bec5"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/batteryEstimateExample1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Per-hour consumption: ~7.6%"
                android:textSize="10sp"
                android:textColor="#e6edf3"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/batteryEstimateExample2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• At 100% battery: ~13.1 hours"
                android:textSize="10sp"
                android:textColor="#e6edf3" />
        </LinearLayout>
    </LinearLayout>

    </LinearLayout>
</ScrollView>
