<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_watch_fullscreen.xml
    Watch fullscreen with live camera preview.
    TextureView fills the screen (bottom layer); status/timer/back overlay on top.
    Safe-zone: back button at bottom-center, status at top-center.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Live camera preview — fills the entire screen, below all overlays -->
    <TextureView
        android:id="@+id/tv_watch_fs_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Recording status dot + label (top-center, safe zone ~40dp from top) -->
    <TextView
        android:id="@+id/tv_watch_fs_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="44dp"
        android:text="@string/watch_status_recording"
        android:textColor="#FF5252"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.06" />

    <!-- Timer (large, centered) -->
    <TextView
        android:id="@+id/tv_watch_fs_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="00:00:00"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:fontFamily="monospace" />

    <!-- Back button (bottom-center, safe zone ~40dp from bottom) — matches trash screen style -->
    <ImageView
        android:id="@+id/btn_watch_fs_back"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="40dp"
        android:src="@drawable/ic_arrow_back"
        android:tint="@android:color/white"
        android:scaleType="fitCenter"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/back" />

</FrameLayout>
