<?xml version="1.0" encoding="utf-8"?>
<ScrollView android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fillViewport="true"
    android:background="@color/black"
    android:clipChildren="false"
    android:clipToPadding="false"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false">

        <com.fadcam.ui.IconRainView
            android:id="@+id/iconRainView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.35"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Avatar: starts sleeping, wakes on-screen to greet the user -->
        <ImageView
            android:id="@+id/ivOnboardingAvatar"
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:src="@drawable/toggle_off"
            android:contentDescription="@string/app_name"
            android:layout_marginTop="68dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ZzZ floating letters above-right during sleep -->
        <TextView
            android:id="@+id/tvOnboardZ1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="z"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#CCFFFFFF"
            android:fontFamily="monospace"
            android:visibility="invisible"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="2dp"
            app:layout_constraintEnd_toEndOf="@id/ivOnboardingAvatar"
            app:layout_constraintBottom_toTopOf="@id/ivOnboardingAvatar" />

        <TextView
            android:id="@+id/tvOnboardZ2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Z"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#CCFFFFFF"
            android:fontFamily="monospace"
            android:visibility="invisible"
            android:layout_marginEnd="2dp"
            android:layout_marginBottom="14dp"
            app:layout_constraintEnd_toEndOf="@id/ivOnboardingAvatar"
            app:layout_constraintBottom_toTopOf="@id/ivOnboardingAvatar" />

        <TextView
            android:id="@+id/tvOnboardZ3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Z"
            android:textSize="23sp"
            android:textStyle="bold"
            android:textColor="#CCFFFFFF"
            android:fontFamily="monospace"
            android:visibility="invisible"
            android:layout_marginEnd="-8dp"
            android:layout_marginBottom="28dp"
            app:layout_constraintEnd_toEndOf="@id/ivOnboardingAvatar"
            app:layout_constraintBottom_toTopOf="@id/ivOnboardingAvatar" />

        <!-- Greeting text: pops in on wake, cycles Hi -> سلام -->
        <TextView
            android:id="@+id/tvHiGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hi!"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:fontFamily="monospace"
            android:rotation="-10"
            android:elevation="4dp"
            android:visibility="invisible"
            android:layout_marginEnd="-16dp"
            android:layout_marginTop="-10dp"
            app:layout_constraintEnd_toEndOf="@id/ivOnboardingAvatar"
            app:layout_constraintTop_toTopOf="@id/ivOnboardingAvatar" />

        <TextView
            android:id="@+id/tvOnboardingDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="@dimen/onboarding_desc_size"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:lineSpacingExtra="3dp"
            android:layout_marginTop="12dp"
            android:paddingLeft="@dimen/onboarding_margin"
            android:paddingRight="@dimen/onboarding_margin"
            app:layout_constraintTop_toBottomOf="@id/ivOnboardingAvatar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guidelineArrowBottom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.80" />

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottieArrow"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:visibility="invisible"
            android:layoutDirection="ltr"
            app:lottie_fileName="right_arrow_red.json"
            app:lottie_autoPlay="false"
            app:lottie_loop="false"
            app:layout_constraintTop_toBottomOf="@id/tvOnboardingDescription"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tvSwipeInstruction"
            android:layout_marginTop="0dp" />

        <TextView
            android:id="@+id/tvSwipeInstruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_swipe_instruction"
            android:textSize="@dimen/onboarding_title_size"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layoutDirection="ltr"
            android:visibility="invisible"
            app:layout_constraintTop_toBottomOf="@id/lottieArrow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="48dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView> 