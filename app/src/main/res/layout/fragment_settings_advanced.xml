<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <!-- Fixed Header -->
    <LinearLayout
        android:id="@+id/header_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:background="@drawable/header_bar_rounded_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <ImageView
            android:id="@+id/back_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:padding="2dp"
            android:src="@drawable/ic_close"
            android:contentDescription="@string/watch_back_desc"
            android:tint="@android:color/white"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_advanced_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp"
            android:textColor="@android:color/white"
            android:textAlignment="viewStart"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/content_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingBottom="76dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/header_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp">

            <LinearLayout
                android:id="@+id/group_card_advanced"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/settings_group_card_bg"

>

            <LinearLayout
                android:id="@+id/row_motion_lab"
                style="@style/SettingsGroupRow"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_focus_target"
                    android:tint="@android:color/darker_gray"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/motion_lab_title"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="?attr/colorHeading"
                        android:textAlignment="viewStart"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/motion_lab_row_subtitle"
                        android:textColor="@android:color/darker_gray"
                        android:textSize="12sp"
                        android:textAlignment="viewStart"/>
                </LinearLayout>
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@android:color/darker_gray"/>
            </LinearLayout>

            <View style="@style/SettingsDivider" />

            <LinearLayout
                android:id="@+id/row_digital_forensics"
                style="@style/SettingsGroupRow"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_debug"
                    android:tint="@android:color/darker_gray"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/digital_forensics_title"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="?attr/colorHeading"
                        android:textAlignment="viewStart"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/digital_forensics_row_subtitle"
                        android:textColor="@android:color/darker_gray"
                        android:textSize="12sp"
                        android:textAlignment="viewStart"/>
                </LinearLayout>
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@android:color/darker_gray"/>
            </LinearLayout>

            <View style="@style/SettingsDivider" />

            <LinearLayout
                android:id="@+id/row_thermal_guardian"
                style="@style/SettingsGroupRow"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_thermometer"
                    android:tint="@android:color/darker_gray"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/thermal_guardian_title"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="?attr/colorHeading"
                            android:textAlignment="viewStart"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:paddingHorizontal="6dp"
                            android:paddingVertical="2dp"
                            android:text="@string/remote_coming_soon_badge"
                            android:textColor="#FFFFFF"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_coming_soon_badge"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/thermal_guardian_row_subtitle"
                        android:textColor="@android:color/darker_gray"
                        android:textSize="12sp"
                        android:textAlignment="viewStart"/>
                </LinearLayout>
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@android:color/darker_gray"/>
            </LinearLayout>

            <View style="@style/SettingsDivider" />

            <LinearLayout
                android:id="@+id/row_audio_vision"
                style="@style/SettingsGroupRow"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_audio"
                    android:tint="@android:color/darker_gray"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/audio_vision_title"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="?attr/colorHeading"
                            android:textAlignment="viewStart"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:paddingHorizontal="6dp"
                            android:paddingVertical="2dp"
                            android:text="@string/remote_coming_soon_badge"
                            android:textColor="#FFFFFF"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_coming_soon_badge"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/audio_vision_row_subtitle"
                        android:textColor="@android:color/darker_gray"
                        android:textSize="12sp"
                        android:textAlignment="viewStart"/>
                </LinearLayout>
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@android:color/darker_gray"/>
            </LinearLayout>

            <View style="@style/SettingsDivider" />

            <LinearLayout
                android:id="@+id/row_scheduled_recording"
                style="@style/SettingsGroupRow"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_schedule"
                    android:tint="@android:color/darker_gray"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/scheduled_recording_title"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="?attr/colorHeading"
                            android:textAlignment="viewStart"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:paddingHorizontal="6dp"
                            android:paddingVertical="2dp"
                            android:text="@string/remote_coming_soon_badge"
                            android:textColor="#FFFFFF"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_coming_soon_badge"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/scheduled_recording_row_subtitle"
                        android:textColor="@android:color/darker_gray"
                        android:textSize="12sp"
                        android:textAlignment="viewStart"/>
                </LinearLayout>
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@android:color/darker_gray"/>
            </LinearLayout>

            <View style="@style/SettingsDivider" />

            <LinearLayout
                android:id="@+id/row_profiles"
                style="@style/SettingsGroupRow"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_profiles"
                    android:tint="@android:color/darker_gray"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/profiles_title"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="?attr/colorHeading"
                            android:textAlignment="viewStart"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:paddingHorizontal="6dp"
                            android:paddingVertical="2dp"
                            android:text="@string/remote_coming_soon_badge"
                            android:textColor="#FFFFFF"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_coming_soon_badge"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profiles_row_subtitle"
                        android:textColor="@android:color/darker_gray"
                        android:textSize="12sp"
                        android:textAlignment="viewStart"/>
                </LinearLayout>
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@android:color/darker_gray"/>
            </LinearLayout>

            <View style="@style/SettingsDivider" />

            <LinearLayout
                android:id="@+id/row_fadcrypt"
                style="@style/SettingsGroupRow"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_fadcrypt"
                    android:tint="@android:color/darker_gray"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/fadcrypt_title"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="?attr/colorHeading"
                            android:textAlignment="viewStart"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:paddingHorizontal="6dp"
                            android:paddingVertical="2dp"
                            android:text="@string/remote_coming_soon_badge"
                            android:textColor="#FFFFFF"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_coming_soon_badge"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/fadcrypt_row_subtitle"
                        android:textColor="@android:color/darker_gray"
                        android:textSize="12sp"
                        android:textAlignment="viewStart"/>
                </LinearLayout>
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@android:color/darker_gray"/>
            </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
