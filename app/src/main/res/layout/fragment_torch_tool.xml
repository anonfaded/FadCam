<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <!-- Fixed Header Bar -->
    <LinearLayout
        android:id="@+id/header_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:background="@drawable/header_bar_rounded_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/torch_close_btn"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:padding="2dp"
            android:src="@drawable/ic_close"
            android:contentDescription="@string/button_close"
            android:tint="@android:color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <com.fadcam.ui.utils.AnimatedTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="start|center_vertical"
                android:text="@string/mini_app_torch_title"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>
    </LinearLayout>

    <!-- Scrollable Body -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls"
        app:layout_constraintTop_toBottomOf="@id/header_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Top spacer to center torch vertically -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.3" />

            <!-- Hero torch button section -->
            <FrameLayout
                android:id="@+id/torch_button_area"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true">

                <View
                    android:id="@+id/torch_glow"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_torch_glow_ring"
                    android:visibility="gone" />

                <com.fadcam.ui.AvatarToggleView
                    android:id="@+id/torch_toggle"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:clickable="false"
                    android:focusable="false" />

            </FrameLayout>

            <!-- Status label -->
            <TextView
                android:id="@+id/torch_status_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/torch_tap_to_enable"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:textColor="#80FFFFFF" />

            <!-- Pattern section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="36dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/mini_app_torch_patterns_title"
                    android:textColor="?attr/colorHeading"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:alpha="0.55" />

                <TextView
                    android:id="@+id/pattern_info_btn"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:fontFamily="@font/materialicons"
                    android:text="info"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:textColor="?attr/colorOnSurface"
                    android:alpha="0.45"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/button_info" />

            </LinearLayout>

            <!-- Pattern chips (filled dynamically in Java) -->
            <LinearLayout
                android:id="@+id/pattern_chips_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:gravity="center" />

            <!-- Light & Timer group card -->
            <LinearLayout
                android:id="@+id/torch_light_timer_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/settings_group_card_bg">

                <!-- Screen Light row -->
                <LinearLayout
                    android:id="@+id/screen_light_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:minHeight="56dp"
                    android:background="@drawable/settings_home_row_bg"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:fontFamily="@font/materialicons"
                        android:text="light_mode"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:textColor="?attr/colorHeading"
                        android:layout_marginEnd="16dp"
                        android:contentDescription="@null" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_gravity="center_vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/torch_screen_light_label"
                            android:textColor="?attr/colorHeading"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/torch_screen_light_desc"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="12sp"
                            android:alpha="0.6" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/screen_light_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/torch_status_off"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#66FFFFFF"
                        android:layout_marginEnd="8dp" />

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_arrow_right"
                        android:tint="@android:color/darker_gray"
                        android:contentDescription="@null" />

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="12dp"
                    android:background="#FF262626" />

                <!-- Auto-off timer row -->
                <LinearLayout
                    android:id="@+id/torch_timer_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:minHeight="56dp"
                    android:background="@drawable/settings_home_row_bg"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:fontFamily="@font/materialicons"
                        android:text="timer"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:textColor="?attr/colorHeading"
                        android:layout_marginEnd="16dp"
                        android:contentDescription="@null" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_gravity="center_vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/torch_timer_label"
                            android:textColor="?attr/colorHeading"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/torch_timer_desc"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="12sp"
                            android:alpha="0.6" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/torch_timer_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/torch_timer_off"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#66FFFFFF"
                        android:layout_marginEnd="8dp" />

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_arrow_right"
                        android:tint="@android:color/darker_gray"
                        android:contentDescription="@null" />

                </LinearLayout>

            </LinearLayout>

            <!-- Screen Light row -->
            <LinearLayout
                android:id="@+id/screen_light_row_old"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:paddingStart="14dp"
                android:paddingEnd="12dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:minHeight="56dp"
                android:background="@drawable/settings_home_row_bg"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:fontFamily="@font/materialicons"
                    android:text="light_mode"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:textColor="?attr/colorHeading"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="@null" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_gravity="center_vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/torch_screen_light_label"
                        android:textColor="?attr/colorHeading"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/torch_screen_light_desc"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="12sp"
                        android:alpha="0.6" />

                </LinearLayout>

                <TextView
                    android:id="@+id/screen_light_status_old"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/torch_status_off"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#66FFFFFF"
                    android:layout_marginEnd="8dp" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@android:color/darker_gray"
                    android:contentDescription="@null" />

            </LinearLayout>

            <!-- Auto-off timer row -->
            <LinearLayout
                android:id="@+id/torch_timer_row_old"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:paddingStart="14dp"
                android:paddingEnd="12dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:minHeight="56dp"
                android:background="@drawable/settings_home_row_bg"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:fontFamily="@font/materialicons"
                    android:text="timer"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:textColor="?attr/colorHeading"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="@null" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_gravity="center_vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/torch_timer_label"
                        android:textColor="?attr/colorHeading"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/torch_timer_desc"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="12sp"
                        android:alpha="0.6" />

                </LinearLayout>

                <TextView
                    android:id="@+id/torch_timer_status_old"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/torch_timer_off"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#66FFFFFF"
                    android:layout_marginEnd="8dp" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@android:color/darker_gray"
                    android:contentDescription="@null" />

            </LinearLayout>

            <!-- Bottom spacer to center torch vertically -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.4" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
