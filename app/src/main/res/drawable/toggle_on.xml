<?xml version="1.0" encoding="utf-8"?>
<!--
  ON state base vector (used by toggle_on_anim.xml AnimatedVectorDrawable).
  eye_group starts at scaleY=0 (eyelids fully closed).
  pivotY=198 = the chord (flat top of the eye arc).
  AVD animates scaleY 0→1 (eyelids open upward from chord).
  After AVD: swap to toggle_on_idle.xml (scaleY=1, seamless match).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="52dp"
    android:height="52dp"
    android:viewportWidth="400"
    android:viewportHeight="400">

    <!-- Head sphere: radial gradient, lit from upper-left -->
    <path
        android:name="head"
        android:pathData="M 30,200 A 170,170 0 1,0 370,200 A 170,170 0 1,0 30,200 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="150"
                android:centerY="100"
                android:gradientRadius="280"
                android:startColor="#c8c8c8"
                android:endColor="#2e2e2e" />
        </aapt:attr>
    </path>

    <!--
      eye_group: pivotY=198 (at the chord) so scaleY scales from that axis.
      scaleY=0 = eyes closed flush with chord (awaiting AVD to open them).
    -->
    <!--
      Wake-up AVD base: identical to toggle_off.xml so the swap is seamless.
      Eyes full-size dark gray at droop position (translateY=25).
      AVD animates: translateY 25→0 + fillColor #808080→#ffffff = rise + brighten.
    -->
    <group
        android:name="eye_group"
        android:translateX="0"
        android:translateY="20"
        android:pivotX="200"
        android:pivotY="165"
        android:scaleY="1.0">

        <!-- LEFT eye: perfect semicircle (A arc), dark for sleep (AVD base = same as toggle_off) -->
        <path
            android:name="left_eye"
            android:pathData="M 90,165 A 40,40 0 0 0 170,165 Z"
            android:fillColor="#2a2a2a"
            android:fillAlpha="1" />

        <!-- RIGHT eye: perfect semicircle, dark for sleep -->
        <path
            android:name="right_eye"
            android:pathData="M 230,165 A 40,40 0 0 0 310,165 Z"
            android:fillColor="#2a2a2a"
            android:fillAlpha="1" />

    </group>

</vector>

