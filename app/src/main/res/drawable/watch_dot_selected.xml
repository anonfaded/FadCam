<?xml version="1.0" encoding="utf-8"?>
<!-- Changed from #FF5252 (red) to white for better visibility and to prevent
     visual artifacts on Wear OS round screens. Red indicator was contributing
     to red overlay impression on small watch displays. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="@android:color/white" />
</shape>
