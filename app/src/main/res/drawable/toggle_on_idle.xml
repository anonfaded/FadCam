<?xml version="1.0" encoding="utf-8"?>
<!--
  ON idle state: eyes FULLY OPEN (scaleY=1.0).
  Used as:
  - Static display after AVD finishes (fix for "eyes disappear on re-open" bug)
  - Base for toggle_off_anim.xml (eyes open → closing transition)
  - Base for toggle_on_blink.xml (eyes open → blink → open)
  pivotY=198 at the chord so blink/close transitions animate correctly.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="52dp"
    android:height="52dp"
    android:viewportWidth="400"
    android:viewportHeight="400">

    <!-- Head sphere: same gradient as toggle_on.xml -->
    <path
        android:name="head"
        android:pathData="M 30,200 A 170,170 0 1,0 370,200 A 170,170 0 1,0 30,200 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="150"
                android:centerY="100"
                android:gradientRadius="280"
                android:startColor="#c8c8c8"
                android:endColor="#2e2e2e" />
        </aapt:attr>
    </path>

    <!-- eye_group: fully awake (scaleY=1.0, translateY=0). pivotY=178 for animations. -->
    <group
        android:name="eye_group"
        android:translateX="0"
        android:translateY="0"
        android:pivotX="200"
        android:pivotY="165"
        android:scaleY="1.0">

        <!-- LEFT eye neon glow: 6 tightly-spaced halos with exponential falloff -->
        <path android:pathData="M 62,165 A 68,68 0 0 0 198,165 Z"
              android:fillColor="#ffffff" android:fillAlpha="0.02" />
        <path android:pathData="M 70,165 A 60,60 0 0 0 190,165 Z"
              android:fillColor="#ffffff" android:fillAlpha="0.05" />
        <path android:pathData="M 76,165 A 54,54 0 0 0 184,165 Z"
              android:fillColor="#ffffff" android:fillAlpha="0.10" />
        <path android:pathData="M 81,165 A 49,49 0 0 0 179,165 Z"
              android:fillColor="#ffffff" android:fillAlpha="0.18" />
        <path android:pathData="M 85,165 A 45,45 0 0 0 175,165 Z"
              android:fillColor="#ffffff" android:fillAlpha="0.28" />
        <path android:pathData="M 88,165 A 42,42 0 0 0 172,165 Z"
              android:fillColor="#ffffff" android:fillAlpha="0.38" />

        <!-- LEFT eye: solid bright core on top -->
        <path
            android:name="left_eye"
            android:pathData="M 90,165 A 40,40 0 0 0 170,165 Z"
            android:fillColor="#ffffff"
            android:fillAlpha="1" />

        <!-- RIGHT eye neon glow: 6 tightly-spaced halos -->
        <path android:pathData="M 202,165 A 68,68 0 0 0 338,165 Z"
              android:fillColor="#ffffff" android:fillAlpha="0.02" />
        <path android:pathData="M 210,165 A 60,60 0 0 0 330,165 Z"
              android:fillColor="#ffffff" android:fillAlpha="0.05" />
        <path android:pathData="M 216,165 A 54,54 0 0 0 324,165 Z"
              android:fillColor="#ffffff" android:fillAlpha="0.10" />
        <path android:pathData="M 221,165 A 49,49 0 0 0 319,165 Z"
              android:fillColor="#ffffff" android:fillAlpha="0.18" />
        <path android:pathData="M 225,165 A 45,45 0 0 0 315,165 Z"
              android:fillColor="#ffffff" android:fillAlpha="0.28" />
        <path android:pathData="M 228,165 A 42,42 0 0 0 312,165 Z"
              android:fillColor="#ffffff" android:fillAlpha="0.38" />

        <!-- RIGHT eye: solid bright core on top -->
        <path
            android:name="right_eye"
            android:pathData="M 230,165 A 40,40 0 0 0 310,165 Z"
            android:fillColor="#ffffff"
            android:fillAlpha="1" />

    </group>

</vector>

