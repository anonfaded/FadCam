<?xml version="1.0" encoding="utf-8"?>
<!--
  ON idle state: eyes FULLY OPEN (scaleY=1.0).
  Used as:
  - Static display after AVD finishes (fix for "eyes disappear on re-open" bug)
  - Base for toggle_off_anim.xml (eyes open → closing transition)
  - Base for toggle_on_blink.xml (eyes open → blink → open)
  pivotY=198 at the chord so blink/close transitions animate correctly.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="52dp"
    android:height="52dp"
    android:viewportWidth="400"
    android:viewportHeight="400">

    <!-- Head sphere: same gradient as toggle_on.xml -->
    <path
        android:name="head"
        android:pathData="M 30,200 A 170,170 0 1,0 370,200 A 170,170 0 1,0 30,200 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="150"
                android:centerY="100"
                android:gradientRadius="280"
                android:startColor="#c8c8c8"
                android:endColor="#2e2e2e" />
        </aapt:attr>
    </path>

    <!-- eye_group: fully awake (scaleY=1.0, translateY=0). pivotY=178 for animations. -->
    <group
        android:name="eye_group"
        android:translateX="0"
        android:translateY="0"
        android:pivotX="200"
        android:pivotY="165"
        android:scaleY="1.0">

        <!-- LEFT eye neon glow.
             5 semicircle (dome) halos: same shape as eye, slightly larger, sweepFlag=0 (upward arc).
             3 flat-oval halos: below the chord (sweepFlag=1, downward arc), most visible against
             the dark card background below the avatar.  Eye fill (alpha=1) on top. -->

        <!-- Dome halos (sweepFlag=0 = same dome direction as eye) -->
        <path android:pathData="M 89,165 A 41,41 0 0 0 171,165 Z" android:fillColor="#ffffff" android:fillAlpha="0.16" />
        <path android:pathData="M 87,165 A 43,43 0 0 0 173,165 Z" android:fillColor="#ffffff" android:fillAlpha="0.10" />
        <path android:pathData="M 84,165 A 46,46 0 0 0 176,165 Z" android:fillColor="#ffffff" android:fillAlpha="0.05" />
        <path android:pathData="M 80,165 A 50,50 0 0 0 180,165 Z" android:fillColor="#ffffff" android:fillAlpha="0.02" />

        <!-- Flat-bottom halos (sweepFlag=1 = downward arc below the chord) -->
        <path android:pathData="M 90,165 A 40,6 0 0 1 170,165 Z" android:fillColor="#ffffff" android:fillAlpha="0.22" />
        <path android:pathData="M 88,165 A 42,11 0 0 1 172,165 Z" android:fillColor="#ffffff" android:fillAlpha="0.12" />
        <path android:pathData="M 84,165 A 46,18 0 0 1 176,165 Z" android:fillColor="#ffffff" android:fillAlpha="0.05" />

        <!-- LEFT eye: solid bright core on top -->
        <path
            android:name="left_eye"
            android:pathData="M 90,165 A 40,40 0 0 0 170,165 Z"
            android:fillColor="#ffffff"
            android:fillAlpha="1" />

        <!-- RIGHT eye neon glow -->

        <!-- Dome halos -->
        <path android:pathData="M 229,165 A 41,41 0 0 0 311,165 Z" android:fillColor="#ffffff" android:fillAlpha="0.16" />
        <path android:pathData="M 227,165 A 43,43 0 0 0 313,165 Z" android:fillColor="#ffffff" android:fillAlpha="0.10" />
        <path android:pathData="M 224,165 A 46,46 0 0 0 316,165 Z" android:fillColor="#ffffff" android:fillAlpha="0.05" />
        <path android:pathData="M 220,165 A 50,50 0 0 0 320,165 Z" android:fillColor="#ffffff" android:fillAlpha="0.02" />

        <!-- Flat-bottom halos -->
        <path android:pathData="M 230,165 A 40,6 0 0 1 310,165 Z" android:fillColor="#ffffff" android:fillAlpha="0.22" />
        <path android:pathData="M 228,165 A 42,11 0 0 1 312,165 Z" android:fillColor="#ffffff" android:fillAlpha="0.12" />
        <path android:pathData="M 224,165 A 46,18 0 0 1 316,165 Z" android:fillColor="#ffffff" android:fillAlpha="0.05" />

        <!-- RIGHT eye: solid bright core on top -->
        <path
            android:name="right_eye"
            android:pathData="M 230,165 A 40,40 0 0 0 310,165 Z"
            android:fillColor="#ffffff"
            android:fillAlpha="1" />

    </group>

</vector>

