<?xml version="1.0" encoding="utf-8"?>
<!--
  Cascading "Z z z" badge for sleeping/off state.
  Three Z-letterforms drawn as stroked paths, grouped with a tilt
  so they look like they're floating upward (like 😴 emoji zzz).
  Z path formula: M tx,ty  L bx,ty  L tx,by  L bx,by
    (top-horiz → diagonal ↙ → bottom-horiz)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="28dp"
    android:height="28dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <!-- Tilted floating group: rotate −18° around centre -->
    <group
        android:rotation="-18"
        android:pivotX="50"
        android:pivotY="50">

        <!-- z  (small, bottom / most faded) -->
        <path
            android:pathData="M 10,68 L 30,68 L 10,82 L 30,82"
            android:strokeColor="#88ccff"
            android:strokeWidth="5"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:fillColor="#00000000"
            android:alpha="0.5" />

        <!-- Z  (medium, middle) -->
        <path
            android:pathData="M 28,42 L 58,42 L 28,62 L 58,62"
            android:strokeColor="#bbddff"
            android:strokeWidth="6"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:fillColor="#00000000"
            android:alpha="0.75" />

        <!-- Z  (large, top / brightest) -->
        <path
            android:pathData="M 46,12 L 86,12 L 46,38 L 86,38"
            android:strokeColor="#ffffff"
            android:strokeWidth="7"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:fillColor="#00000000" />

    </group>

</vector>
