<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused state: brighter surface so D-pad highlight is visible on TV/remote -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#3AFFFFFF"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
    <!-- Default state: dark card background with ripple on press -->
    <item>
        <ripple android:color="#7A000000">
            <item android:id="@android:id/mask">
                <shape android:shape="rectangle">
                    <solid android:color="#FFFFFF"/>
                    <corners android:radius="8dp"/>
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/dark_card_background"/>
                    <corners android:radius="8dp"/>
                </shape>
            </item>
        </ripple>
    </item>
</selector>
