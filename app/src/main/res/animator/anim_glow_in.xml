<?xml version="1.0" encoding="utf-8"?>
<!--
  Glow group fade-in: animates the eye glow <group> android:alpha from 0 → 1.
  Runs simultaneously with anim_eye_brighten.xml in toggle_on_anim.xml.
  Duration matches eye brighten so the glow reaches full brightness exactly when eyes turn white.
-->
<objectAnimator
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:propertyName="alpha"
    android:valueFrom="0"
    android:valueTo="1"
    android:duration="420"
    android:interpolator="@android:interpolator/decelerate_cubic" />
