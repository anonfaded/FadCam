<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.FadCam" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your dark theme here. -->
        <!-- <item name="colorPrimary">@color/my_dark_primary</item> -->
        <item name="android:fontFamily">@font/ubuntu_regular</item>
<!--        the color for statusbar at top-->
        <item name="android:statusBarColor">@color/gray</item>
        <item name="colorTopBar">@color/gray</item>
        <item name="colorBottomNav">@color/gray</item>
        <item name="colorHeading">@color/colorHeading</item>
        <item name="colorButton">@color/colorButton</item>
