        <item name="homeRailTextPrimary">#F3F4F6</item>
        <item name="homeRailTextSecondary">#B4B8BE</item>
        <item name="homeRailAccent">#BFCBDA</item>
        
        <!-- Picker component overrides for better contrast in Faded Night theme ONLY -->
        <item name="pickerButtonBackground">@color/picker_button_background</item>
        <item name="pickerButtonText">@color/picker_button_text</item>
        <item name="pickerIconTint">@color/picker_icon_tint</item>
        <item name="pickerSliderActive">@color/picker_slider_active</item>
        <item name="pickerSliderInactive">@color/picker_slider_inactive</item>
    
        <item name="android:colorBackground">@color/black</item>
