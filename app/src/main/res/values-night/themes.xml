        <item name="colorSwitchTrack">@color/gray</item>
        <item name="colorDialog">@color/colorDialog</item>
        <item name="colorStatusBar">@color/colorStatusBar</item>
        <!-- Picker gradient colors - subtle gray gradient for night themes -->
        <item name="pickerGradientStart">@color/black</item>
        <item name="pickerGradientMid">#FF2A2A2A</item>
        <item name="pickerGradientEnd">#FF404040</item>
        <!-- Picker text colors -->
        <item name="pickerTextPrimary">@android:color/white</item>
